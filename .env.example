PORT=3000
MONGO_URI=mongodb://localhost:27017/amazon_pay
NODE_ENV=development

# ── Amazon RVS (Receipt Verification Service) ──────────────────────────────
# Your Amazon Developer Secret from the Amazon Developer Console
# Developer Console → My Apps → [Your App] → In-App Items → API Key
AMAZON_DEVELOPER_SECRET=your_developer_secret_here

# Set to "true" to call the RVS Sandbox; "false" or omit for production
AMAZON_RVS_SANDBOX=true
